# Version check configuration
VERSION_FILE="/usr/local/share/rhcsa/.version"
GITHUB_REPO_API="https://api.github.com/repos/RHCSA/RHCSA.github.io/commits/main"
INSTALLER_URL="https://raw.githubusercontent.com/RHCSA/RHCSA.github.io/main/Install_RHCSA_EX200_Exam_Simulator.sh"

# Check for updates on startup
check_for_update() {
    # Only check if version file exists (installed via installer)
    if [[ ! -f "$VERSION_FILE" ]]; then
        return 0
    fi
    
    # Check if we have internet connectivity
    if ! curl -sI https://github.com --connect-timeout 3 &>/dev/null; then
        return 0  # Skip update check if offline
    fi
    
    local installed_commit=$(cat "$VERSION_FILE" 2>/dev/null)
    local latest_commit=$(curl -sL "$GITHUB_REPO_API" 2>/dev/null | grep '"sha"' | head -1 | sed 's/.*"sha": "\([^"]*\)".*/\1/')
    
    if [[ -n "$latest_commit" ]] && [[ "$installed_commit" != "$latest_commit" ]]; then
        clear_screen
        echo ""
        echo -e "  ${CYAN}${BOLD}╔════════════════════════════════════════════════════════════╗${RESET}"
        echo -e "  ${CYAN}${BOLD}║                  Update Available!                          ║${RESET}"
        echo -e "  ${CYAN}${BOLD}╚════════════════════════════════════════════════════════════╝${RESET}"
        echo ""
        echo -e "  A new version of RHCSA Exam Simulator is available."
        echo ""
        echo -e "  Installed: ${YELLOW}${installed_commit:0:7}${RESET}"
        echo -e "  Latest:    ${GREEN}${latest_commit:0:7}${RESET}"
        echo ""
        echo -ne "  Do you want to update now? (y/n): "
        read -n 1 -r reply
        echo ""
        
        if [[ $reply =~ ^[Yy]$ ]]; then
            echo ""
            echo -e "  ${CYAN}Downloading and running installer...${RESET}"
            echo ""
            show_cursor
            # Download installer to temp file and run with --force flag
            local tmp_installer="/tmp/rhcsa_update_$$.sh"
            curl -sL "$INSTALLER_URL" -o "$tmp_installer"
            chmod +x "$tmp_installer"
            # Run installer with --force to skip prompts, then cleanup and exit
            exec bash "$tmp_installer" --force
        else
            echo ""
            echo -e "  ${YELLOW}Update skipped. Run 'rhcsa' again to update later.${RESET}"
            echo ""
            sleep 2
        fi
    fi
}

# Pre-script checks
pre_script_checks() {
    local checks_passed=true
    clear_screen
    echo ""
    echo -e "  ${TITLE}🔍 Checking Exam Simulator Requirements...${RESET}"
    echo -e "  ${DIM}──────────────────────────────────────────${RESET}"
    echo ""
    
    # Check 1: Root user check
    echo -ne "  ${DIM}• Checking user permissions...${RESET}"
    if [[ $EUID -ne 0 ]]; then
        echo -e " ${RED}✗ FAILED${RESET}"
        echo ""
        echo -e "  ${RED}${BOLD}ERROR: This script must be run as root!${RESET}"
        echo ""
        echo -e "  ${YELLOW}Please switch to root user and run the script again:${RESET}"
        echo -e "  ${CYAN}  # sudo su root ${RESET}"
        echo -e "  ${CYAN}  # rhcsa ${RESET}"
        echo ""
        sleep 2
        exit 1
    fi
    echo -e " ${GREEN}✓ Running as root${RESET}"
    
    # Check 2: tmux installation
    echo -ne "  ${DIM}• Checking tmux installation...${RESET}"
    if ! command -v tmux &>/dev/null; then
        echo -e " ${YELLOW}⚠ Not installed${RESET}"
        echo ""
        echo -e "  ${CYAN}Installing tmux...${RESET}"
        
        # Detect package manager and install tmux
        if command -v dnf &>/dev/null; then
            dnf install -y tmux &>/dev/null
        elif command -v yum &>/dev/null; then
            yum install -y tmux &>/dev/null
        elif command -v apt-get &>/dev/null; then
            apt-get update &>/dev/null && apt-get install -y tmux &>/dev/null
        elif command -v zypper &>/dev/null; then
            zypper install -y tmux &>/dev/null
        else
            echo -e "  ${RED}✗ Could not detect package manager. Please install tmux manually.${RESET}"
            exit 1
        fi
        
        # Verify installation
        if command -v tmux &>/dev/null; then
            echo -e "  ${GREEN}✓ tmux installed successfully${RESET}"
        else
            echo -e "  ${RED}✗ Failed to install tmux${RESET}"
            exit 1
        fi
        
        # Configure tmux
        echo -ne "  ${DIM}• Configuring tmux...${RESET}"
        configure_tmux
        echo -e " ${GREEN}✓ Configured${RESET}"
    else
        echo -e " ${GREEN}✓ Installed${RESET}"
        
        # Ensure tmux is configured
        if [[ ! -f ~/.tmux.conf ]] || ! grep -q "RHCSA" ~/.tmux.conf 2>/dev/null; then
            echo -ne "  ${DIM}• Configuring tmux...${RESET}"
            configure_tmux
            echo -e " ${GREEN}✓ Configured${RESET}"
        fi
    fi
    
    echo ""
    echo -e "  ${GREEN}${BOLD}✓ All checks passed!${RESET}"
    echo ""
    sleep 0.5
}

# Configure tmux with sensible defaults for RHCSA practice
configure_tmux() {
    cat > ~/.tmux.conf << 'EOF'
# RHCSA Practice Environment - tmux configuration

# Set prefix to Ctrl+a (easier than Ctrl+b)
set -g prefix C-a
unbind C-b
bind C-a send-prefix

# Enable mouse support
set -g mouse on

# Split panes using | and -
bind | split-window -h
bind - split-window -v
unbind '"'
unbind %

# Switch panes using Alt-arrow without prefix
bind -n M-Left select-pane -L
bind -n M-Right select-pane -R
bind -n M-Up select-pane -U
bind -n M-Down select-pane -D

# Start window numbering at 1
set -g base-index 1
setw -g pane-base-index 1

# Reload config file
bind r source-file ~/.tmux.conf \; display "Config reloaded!"

# Status bar styling
set -g status-style 'bg=#cc0000 fg=white'
set -g status-left ' RHCSA '
set -g status-right ' %H:%M '

# Increase history limit
set -g history-limit 10000

# Enable 256 colors
set -g default-terminal "screen-256color"
EOF
}

# Main entry point
main() {
    # Check for special lab monitor mode (called from tmux)
    if [[ "$1" == "--lab-monitor" ]] && [[ -n "$2" ]] && [[ -n "$3" ]]; then
        LAB_OBJ_IDX="$2"
        LAB_Q_IDX="$3"
        CLEAR_ON_EXIT=false
        hide_cursor
        run_lab_monitor "$LAB_OBJ_IDX" "$LAB_Q_IDX"
        exit 0
    fi
    
    # Initialize progress tracking file
    init_progress_file
    
    # Check for updates (only if not running in special modes)
    check_for_update
    
